.hunger-bar-root {
    position: relative;
    width: 100%;
    height: 100%;
}

.hunger-bar-fill-container {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    overflow: hidden;
}

.hunger-bar-fill {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 100%;
}

.hunger-bar-outline {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}
